<style>
  :root {
    --green-dark: #1a3a2a;
    --green-mid: #2d6a4f;
    --green-bright: #52b788;
    --green-light: #b7e4c7;
    --green-pale: #d8f3dc;
    --cream: #f8f5ee;
    --gold: #c9a84c;
    --text-dark: #1a2e1a;
    --text-mid: #3d5a40;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* \u2500\u2500 NOISE TEXTURE OVERLAY \u2500\u2500 */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* \u2500\u2500 NAV \u2500\u2500 */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 5%;
    background: rgba(248, 245, 238, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(45, 106, 79, 0.12);
    transition: box-shadow 0.3s;
  }

  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--green-dark);
    letter-spacing: -0.5px;
  }

  .logo span { color: var(--green-bright); font-style: italic; }

  nav ul {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  nav ul a {
    text-decoration: none;
    color: var(--text-mid);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.3px;
    transition: color 0.2s;
  }

  nav ul a:hover { color: var(--green-bright); }

  .nav-cta {
    background: var(--green-mid);
    color: white !important;
    padding: 0.55rem 1.3rem;
    border-radius: 2rem;
    transition: background 0.2s !important;
  }

  .nav-cta:hover { background: var(--green-dark) !important; color: white !important; }

  /* \u2500\u2500 HERO \u2500\u2500 */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 8rem 5% 4rem;
    background: linear-gradient(135deg, var(--cream) 0%, var(--green-pale) 100%);
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    right: -10%;
    top: -10%;
    width: 60%;
    height: 120%;
    background: radial-gradient(ellipse at center, rgba(82,183,136,0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(82, 183, 136, 0.15);
    color: var(--green-mid);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    border: 1px solid rgba(82, 183, 136, 0.3);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s ease both;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    line-height: 1.1;
    color: var(--green-dark);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.7s ease 0.1s both;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--green-bright);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-mid);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: 2.5rem;
    font-weight: 300;
    animation: fadeUp 0.7s ease 0.2s both;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeUp 0.7s ease 0.3s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--green-mid);
    color: white;
    padding: 0.9rem 2rem;
    border-radius: 3rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
    box-shadow: 0 4px 20px rgba(45,106,79,0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(45,106,79,0.4);
    background: var(--green-dark);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid var(--green-mid);
    color: var(--green-mid);
    padding: 0.9rem 1.8rem;
    border-radius: 3rem;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  .btn-secondary:hover {
    background: var(--green-mid);
    color: white;
  }

  /* Hero Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    animation: fadeIn 1s ease 0.4s both;
  }

